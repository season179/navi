{
  "name": "navi",
  "version": "0.0.1",
  "private": true,
  "description": "a local-first desktop app",
  "main": "dist/main/main.js",
  "scripts": {
    "typecheck": "tsc",
    "build:main": "esbuild src/main/main.ts --bundle --platform=node --external:electron --outfile=dist/main/main.js --sourcemap",
    "build:preload": "esbuild src/main/preload.ts --bundle --platform=node --external:electron --outfile=dist/main/preload.js --sourcemap",
    "build:renderer": "esbuild src/renderer/main.tsx --bundle --platform=browser --define:process.env.NODE_ENV='\"production\"' --outfile=dist/renderer/renderer.js --sourcemap",
    "build": "npm run build:main && npm run build:preload && npm run build:renderer",
    "start": "npm run build && electron ."
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "electron": "^39.8.10",
    "esbuild": "^0.28.1",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@tanstack/react-router": "^1.170.16",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
