{
  "name": "navi",
  "version": "0.0.1",
  "private": true,
  "description": "a local-first desktop app",
  "type": "module",
  "main": "dist/main/main.cjs",
  "packageManager": "npm@11.13.0",
  "scripts": {
    "preinstall": "npx --yes only-allow npm",
    "typecheck": "tsc",
    "build:main": "esbuild src/main/main.ts --bundle --platform=node --format=cjs --external:electron --outfile=dist/main/main.cjs --sourcemap",
    "build:preload": "esbuild src/main/preload.ts --bundle --platform=node --format=cjs --external:electron --outfile=dist/main/preload.cjs --sourcemap",
    "build:renderer": "esbuild src/renderer/main.tsx --bundle --platform=browser --define:process.env.NODE_ENV='\"production\"' --minify --splitting --format=esm --outdir=dist/renderer --entry-names=renderer --sourcemap",
    "build:flue": "flue build --target node && node scripts/patch-flue-server.mjs",
    "build": "npm run build:flue && npm run build:main && npm run build:preload && npm run build:renderer",
    "start": "npm run build && electron .",
    "pretest": "npm run build:flue",
    "test": "node --test \"test/**/*.test.mjs\""
  },
  "devDependencies": {
    "@flue/cli": "1.0.0-beta.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "electron": "42.4.1",
    "esbuild": "0.28.1",
    "typescript": "6.0.3"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/merge": "^6.12.2",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.1",
    "@flue/runtime": "1.0.0-beta.2",
    "@flue/sdk": "1.0.0-beta.1",
    "@tanstack/react-router": "1.170.16",
    "hono": "4.12.26",
    "lucide-react": "1.21.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "remark-gfm": "4.0.1",
    "shiki": "4.2.0",
    "streamdown": "2.5.0"
  }
}
